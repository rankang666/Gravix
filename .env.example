# LLM Provider Configuration
LLM_PROVIDER=claude

# LLM API Configuration (Generic - works for all providers)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=http://your-api-endpoint.com/v1  # Optional: for custom/proxy endpoints
LLM_MODEL=your_model_name_here

# Provider-specific API Keys (Optional fallback)
# These are checked if LLM_API_KEY is not set
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: Fallback API keys for high availability
# If provided, system will automatically switch to fallback if primary fails
# ANTHROPIC_API_KEY_FALLBACK=your_fallback_anthropic_key
# OPENAI_API_KEY_FALLBACK=your_fallback_openai_key

# LLM API timeout in seconds (default: 300)
# Increase this if using slow proxies or internal networks
# LLM_API_TIMEOUT=300

# Resilience Settings (Optional)
# LLM_MAX_RETRIES=3
# LLM_RETRY_DELAY=1.0
# LLM_RATE_LIMIT=0.5

# Alibaba Cloud DataWorks Credentials
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret
ALIBABA_CLOUD_REGION_ID=cn-shenzhen

# === MaxCompute/ODPS Configuration ===
# MaxCompute Project Name
ALIBABA_CLOUD_MAXCOMPUTE_PROJECT=your_project_name_here

# MaxCompute Endpoint
# Examples:
# - China (Shanghai): https://service.cn-shanghai.maxcompute.aliyun.com/api
# - China (Beijing): https://service.cn-beijing.maxcompute.aliyun.com/api
# - China (Hangzhou): https://service.cn-hangzhou.maxcompute.aliyun.com/api
# - China (Shenzhen): https://service.cn-shenzhen.maxcompute.aliyun.com/api
ALIBABA_CLOUD_MAXCOMPUTE_ENDPOINT=https://service.cn-shanghai.maxcompute.aliyun.com/api
